@model SFSWebForm.Models.LoginViewModel
@{
    ViewData["Title"] = "Sign in";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">Sign in</h2>
                <p class="text-muted">Use your approved internal account name or email address to sign in. No passwords are stored.</p>

                <form asp-action="Login" method="post">
                    <input type="hidden" asp-for="ReturnUrl" />
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="mb-3">
                        <label asp-for="Username" class="form-label">Username or email</label>
                        <input asp-for="Username" class="form-control" autocomplete="username" placeholder="username or name@stellantis-fs.com" />
                        <span asp-validation-for="Username" class="text-danger"></span>
                    </div>

                    <div class="form-check mb-3">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label"></label>
                    </div>

                    <button type="submit" class="btn btn-danger w-100">Sign in</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
