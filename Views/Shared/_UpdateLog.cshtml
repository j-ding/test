@model SFSWebForm.Models.Incident
@using SFSWebForm.Models
@{
    // Pre-compute log entries with sequential numbering only for real Update entries
    int _updateCounter = 0;
    var logEntries = new List<(IncidentUpdate Entry, int Num)>();
    foreach (var u in Model.Updates.OrderBy(u => u.CreatedAt))
        logEntries.Add((u, u.EntryType == UpdateEntryType.Update ? ++_updateCounter : 0));
}

@if (logEntries.Any())
{
    <h5 class="fw-semibold mt-4 mb-3">Update Log</h5>
    @foreach (var (entry, num) in logEntries)
    {
        if (entry.EntryType == UpdateEntryType.Resolved)
        {
            <div class="card shadow-sm mb-2 border-success">
                <div class="card-body py-2 px-3 small bg-success-subtle">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fw-semibold text-success">Resolved &mdash; @entry.CreatedAt.ToLocalTime().ToString("MM/dd HH:mm")</span>
                        <span class="badge bg-success">Resolved</span>
                    </div>
                    <p class="mb-0 mt-1 text-muted">@entry.Note</p>
                </div>
            </div>
        }
        else if (entry.EntryType == UpdateEntryType.Reopened)
        {
            <div class="card shadow-sm mb-2 border-warning">
                <div class="card-body py-2 px-3 small bg-warning-subtle">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fw-semibold text-warning-emphasis">Reopened &mdash; @entry.CreatedAt.ToLocalTime().ToString("MM/dd HH:mm")</span>
                        <span class="badge bg-warning text-dark">Reopened</span>
                    </div>
                    <p class="mb-0 mt-1 text-muted">@entry.Note</p>
                </div>
            </div>
        }
        else if (entry.EntryType == UpdateEntryType.EmailSent)
        {
            <div class="card shadow-sm mb-2">
                <div class="card-body py-2 px-3 small">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fw-semibold text-success">&#10003; Email Sent &mdash; @entry.CreatedAt.ToLocalTime().ToString("MM/dd HH:mm")</span>
                        <span class="badge bg-success">Sent</span>
                    </div>
                    <p class="mb-0 mt-1 text-muted">@entry.Note</p>
                </div>
            </div>
        }
        else if (entry.EntryType == UpdateEntryType.EmailSendFailed)
        {
            <div class="card shadow-sm mb-2 border-danger">
                <div class="card-body py-2 px-3 small bg-danger-subtle">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fw-semibold text-danger">&#9888; Send Failed &mdash; @entry.CreatedAt.ToLocalTime().ToString("MM/dd HH:mm")</span>
                        <span class="badge bg-danger">Failed</span>
                    </div>
                    <p class="mb-0 mt-1 text-muted">@entry.Note</p>
                </div>
            </div>
        }
        else if (entry.EntryType == UpdateEntryType.ResolutionDrafted)
        {
            <div class="card shadow-sm mb-2">
                <div class="card-body py-2 px-3 small">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fw-semibold text-muted">Resolution Drafted &mdash; @entry.CreatedAt.ToLocalTime().ToString("MM/dd HH:mm")</span>
                        <span class="badge bg-secondary">Draft</span>
                    </div>
                    <p class="mb-0 mt-1 text-muted">@entry.Note</p>
                </div>
            </div>
        }
        else if (entry.EntryType == UpdateEntryType.EmailEdited)
        {
            <div class="card shadow-sm mb-2">
                <div class="card-body py-2 px-3 small">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fw-semibold text-muted">Email Edited &mdash; @entry.CreatedAt.ToLocalTime().ToString("MM/dd HH:mm")</span>
                        <span class="badge bg-secondary">Edited</span>
                    </div>
                    <p class="mb-0 mt-1 text-muted">@entry.Note</p>
                </div>
            </div>
        }
        else if (entry.EntryType == UpdateEntryType.PriorityChanged)
        {
            <div class="card shadow-sm mb-2">
                <div class="card-body py-2 px-3 small">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fw-semibold text-muted">Priority Changed &mdash; @entry.CreatedAt.ToLocalTime().ToString("MM/dd HH:mm")</span>
                        <span class="badge bg-secondary">Priority</span>
                    </div>
                    <p class="mb-0 mt-1 text-muted">@entry.Note</p>
                </div>
            </div>
        }
        else if (entry.EntryType == UpdateEntryType.SenderChanged)
        {
            <div class="card shadow-sm mb-2">
                <div class="card-body py-2 px-3 small">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fw-semibold text-muted">Send From Changed &mdash; @entry.CreatedAt.ToLocalTime().ToString("MM/dd HH:mm")</span>
                        <span class="badge bg-secondary">Sender</span>
                    </div>
                    <p class="mb-0 mt-1 text-muted">@entry.Note</p>
                </div>
            </div>
        }
        else
        {
            <div class="card shadow-sm mb-2">
                <div class="card-body py-2 px-3 small">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fw-semibold text-muted">Update #@num &mdash; @entry.CreatedAt.ToLocalTime().ToString("MM/dd HH:mm")</span>
                        @if (entry.Status == IncidentStatus.Open)
                        {
                            <span class="badge bg-danger">Open</span>
                        }
                        else if (entry.Status == IncidentStatus.InProgress)
                        {
                            <span class="badge bg-warning text-dark">In Progress</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Resolved</span>
                        }
                    </div>
                    <p class="mb-0 mt-1">@entry.Note</p>
                </div>
            </div>
        }
    }
}
